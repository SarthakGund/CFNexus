# Base URL of the backend REST API (must include the /api suffix).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Backend origin (no /api). Used for OAuth redirect: ${NEXT_PUBLIC_BACKEND_URL}/oauth2/authorization/codeforces
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# WebSocket / STOMP endpoint for live duels.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
