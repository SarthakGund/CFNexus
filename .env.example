# CFNexus — environment variable template.
# Copy to .env and fill in real values:  cp .env.example .env
# Never commit the real .env. All secrets are injected via env vars (spec §17/§21).

# =============================================================================
# Codeforces OAuth + API (spec §4, §21)
# =============================================================================
CF_CLIENT_ID=your_cf_oauth_client_id
CF_CLIENT_SECRET=your_cf_oauth_client_secret
CF_API_KEY=your_cf_api_key            # for signed CF API calls (user.status, etc.)
CF_API_SECRET=your_cf_api_secret

# =============================================================================
# Application database (PostgreSQL) — consumed by backend + docker-compose
# =============================================================================
DB_NAME=cfduel
DB_USERNAME=cfduel
DB_PASSWORD=secret
# JDBC URL used by the backend. Use host 'postgres' when the backend runs in
# docker-compose; 'localhost' when running the backend on the host.
DB_URL=jdbc:postgresql://localhost:5432/cfduel

# =============================================================================
# Redis (app sessions, rate limiting, presence)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret

# =============================================================================
# Session / cookies / CORS
# =============================================================================
SESSION_SECRET=32-char-random-secret
FRONTEND_ORIGIN=http://localhost:3000
# Set to false for local plain-HTTP dev so the session cookie is sent; true in prod.
COOKIE_SECURE=false

# =============================================================================
# Code runner (Judge0) — backend proxy target (spec §12)
# =============================================================================
CODE_RUNNER_URL=http://localhost:2358
CODE_RUNNER_API_KEY=judge0-api-key

# =============================================================================
# Judge0 internal infrastructure (referenced by docker-compose.yml)
# Judge0 runs its OWN dedicated postgres + redis, separate from the app's.
# =============================================================================
JUDGE0_DB_NAME=judge0
JUDGE0_DB_USERNAME=judge0
JUDGE0_DB_PASSWORD=judge0secret
JUDGE0_REDIS_PASSWORD=judge0redis

# =============================================================================
# Frontend (Next.js 15 — NEXT_PUBLIC_ prefix required for client-side access)
# =============================================================================
# Use the nginx-proxied paths in prod (e.g. https://yourdomain.com/api, wss://.../ws).
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
